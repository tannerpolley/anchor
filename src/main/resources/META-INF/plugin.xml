<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.itsjeel01.remoteVcsManager</id>
    <name>Anchor - Remote VCS</name>
    <vendor email="anchor+itsjeel01@gmail.com" url="https://github.com/alph-a07">Jeel Patel</vendor>

    <description><![CDATA[
        <p>Manage GitHub issues, pull requests, and branches without leaving your IDE.</p>

        <p>
            The average developer leaves their IDE for GitHub <strong>38 times a day</strong>.
            Anchor brings your remote repository workflow into a native tool window so that number is zero.
        </p>

        <h3>What you can do</h3>
        <ul>
            <li>Browse <strong>Issues</strong> and <strong>Pull Requests</strong> with filters, state badges, and metadata</li>
            <li>Read full descriptions rendered as GitHub Flavored Markdown - embedded images included</li>
            <li>Post comments without opening a browser tab</li>
            <li>Inspect PR commits with clickable SHAs and source → target branch info</li>
            <li>View and switch <strong>Branches</strong> from the same panel</li>
            <li>Open any item in the browser when you need the full GitHub UI</li>
            <li>Clone repositories, create new ones, and add GitHub remotes via the VCS menu</li>
            <li>Open the current file on GitHub from the editor context menu</li>
        </ul>

        <h3>Setup</h3>
        <ol>
            <li>Go to <strong>Settings → Tools → Anchor - Remote VCS</strong></li>
            <li>Generate and validate a GitHub token in a few clicks</li>
            <li>Open the <strong>Anchor</strong> tool window - your repository is auto-detected from the git remote</li>
        </ol>

        <p>
            Compatible with Android Studio and all IntelliJ-platform IDEs at build 253.1 or later.
            Free and open source - MIT License.
        </p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.jcef</depends>
    <depends>Git4Idea</depends>
    <depends>org.jetbrains.plugins.github</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
                id="Anchor"
                displayType="BALLOON"/>

        <applicationService
                serviceImplementation="com.itsjeel01.remotevcsmanager.settings.RemoteVcsSettingsState"/>

        <applicationConfigurable
                id="com.itsjeel01.remoteVcsManager.settings"
                displayName="Anchor - Remote VCS"
                parentId="tools"
                instance="com.itsjeel01.remotevcsmanager.settings.RemoteVcsConfigurable"/>

        <toolWindow
                id="Anchor"
                anchor="right"
                icon="/META-INF/toolWindow.svg"
                factoryClass="com.itsjeel01.remotevcsmanager.ui.RemoteVcsToolWindowFactory"/>

        <fileEditorProvider
                implementation="com.itsjeel01.remotevcsmanager.ui.editor.AnchorIssueFileEditorProvider"/>

        <postStartupActivity
                implementation="com.itsjeel01.remotevcsmanager.RemoteVcsManagerProjectActivity"/>
    </extensions>

    <actions>
        <action
                id="com.itsjeel01.remoteVcsManager.OpenOnRemote"
                class="com.itsjeel01.remotevcsmanager.actions.OpenOnRemoteAction"
                text="Open on GitHub"
                description="Open the current file on GitHub"
                icon="/icons/openInBrowser.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="CopyPaths"/>
        </action>

        <group
                id="com.itsjeel01.remoteVcsManager.ActionsGroup"
                text="Anchor"
                description="Anchor - Remote VCS actions"
                popup="true">
            <add-to-group group-id="VcsGroups" anchor="last"/>

            <action
                    id="com.itsjeel01.remoteVcsManager.CloneRepository"
                    class="com.itsjeel01.remotevcsmanager.actions.CloneRepositoryAction"
                    text="Clone Repository..."
                    description="Clone a remote repository"
                    icon="/icons/clone.svg"/>

            <action
                    id="com.itsjeel01.remoteVcsManager.CreateRepository"
                    class="com.itsjeel01.remotevcsmanager.actions.CreateRepositoryAction"
                    text="Create Repository on GitHub..."
                    description="Create a new repository on GitHub"
                    icon="/icons/create.svg"/>

            <action
                    id="com.itsjeel01.remoteVcsManager.AddRemote"
                    class="com.itsjeel01.remotevcsmanager.actions.AddRemoteAction"
                    text="Add Remote from GitHub..."
                    description="Add a GitHub repository as a remote to this project"
                    icon="/icons/addRemote.svg"/>
        </group>
    </actions>
</idea-plugin>
